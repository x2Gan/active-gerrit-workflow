# Gerrit base URL, without a trailing slash.
GERRIT_BASE_URL=https://gerrit.example.com

# Default authentication for the first implementation stage is Gerrit HTTP Basic Auth.
GERRIT_AUTH_TYPE=basic
GERRIT_USERNAME=alice

# Use the Gerrit UI generated HTTP Password. Do not commit real credentials.
GERRIT_HTTP_PASSWORD=replace-with-gerrit-http-password

# Optional runtime settings.
GERRIT_VERIFY_SSL=true
GERRIT_TIMEOUT_SECONDS=30
GERRIT_DEFAULT_NOTIFY=OWNER_REVIEWERS
GERRIT_CACHE_DIR=.cache/gerrit

